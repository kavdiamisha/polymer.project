</nav>

<section class="hero">
  <div class="hero-inner">
    <div>
      <div class="hero-badge">Polymer Research Project</div>
      <h1>Welcome to<br/><em>PolyIC</em></h1>
      <p class="hero-sub">A comprehensive platform for polymer chromatography data — connecting researchers, tools, and experimental knowledge in one place.</p>
      <div>
        <a class="btn" href="about.html">Learn More</a>
        <a class="btn btn-outline" href="database-1.html">Browse Database</a>
      </div>
    </div>
    <div class="stats">
      <div class="stat-card"><div class="stat-num">500+</div><div class="stat-label">Polymer Entries in Database</div></div>
      <div class="stat-card"><div class="stat-num">80+</div><div class="stat-label">Peer-Reviewed Publications</div></div>
      <div class="stat-card"><div class="stat-num">20+</div><div class="stat-label">Years of Research</div></div>
      <div class="stat-card"><div class="stat-num">12</div><div class="stat-label">Active Research Projects</div></div>
