  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
  <style>
    :root { --bg:#f4f5f7; --bg-card:#fff; --text:#1a1f2e; --muted:#6b7280; --accent:#3a6ea5; --accent-light:#dbe8f5; --border:#e2e6ec; --serif:'Cormorant Garamond',Georgia,serif; --sans:'DM Sans',sans-serif; }
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
    html{scroll-behavior:smooth;}
    body{font-family:var(--sans);background:var(--bg);color:var(--text);font-size:16px;line-height:1.7;}
    nav{position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(244,245,247,0.97);backdrop-filter:blur(10px);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;padding:0 6vw;height:64px;}
    .nav-brand{font-family:var(--serif);font-size:1.6rem;font-weight:600;color:var(--accent);letter-spacing:0.04em;text-decoration:none;}
    .nav-links{display:flex;gap:0.25rem;list-style:none;align-items:center;}
    .nav-links>li{position:relative;}
    .nav-links>li>a{display:block;padding:0.5rem 1rem;font-size:0.83rem;font-weight:500;color:var(--muted);text-decoration:none;letter-spacing:0.06em;text-transform:uppercase;border-radius:4px;transition:color 0.2s,background 0.2s;}
    .nav-links>li>a:hover,.nav-links>li>a.active{color:var(--accent);background:var(--accent-light);}
    .dropdown-menu{display:none;position:absolute;top:calc(100% + 4px);left:0;min-width:210px;background:var(--bg-card);border:1px solid var(--border);border-radius:10px;box-shadow:0 12px 32px rgba(0,0,0,0.13);overflow:hidden;z-index:200;transition:opacity 0.15s,transform 0.15s;opacity:0;transform:translateY(-6px);pointer-events:none;}
    .nav-links>li.open .dropdown-menu,.nav-links>li:hover .dropdown-menu{display:block;opacity:1;transform:translateY(0);pointer-events:auto;}
    .dropdown-menu a{display:flex;align-items:center;padding:0.85rem 1.4rem;font-size:0.88rem;font-weight:500;color:var(--text);text-decoration:none;transition:background 0.15s,color 0.15s;border-left:3px solid transparent;gap:0.5rem;}
    .dropdown-menu a:hover{background:var(--accent-light);color:var(--accent);border-left-color:var(--accent);}
    .dropdown-menu a:not(:last-child){border-bottom:1px solid var(--border);}
    .nav-dropdown-btn{display:flex;align-items:center;gap:0.3rem;padding:0.5rem 1rem;font-size:0.83rem;font-weight:500;color:var(--muted);letter-spacing:0.06em;text-transform:uppercase;border-radius:4px;cursor:pointer;user-select:none;transition:color 0.2s,background 0.2s;}
    .nav-dropdown-btn .arrow{display:inline-block;transition:transform 0.2s;font-style:normal;}
    .nav-links>li.open .nav-dropdown-btn,.nav-links>li:hover .nav-dropdown-btn{color:var(--accent);background:var(--accent-light);}
    .nav-links>li.open .arrow{transform:rotate(180deg);}
    .page-content{max-width:960px;margin:0 auto;padding:108px 6vw 80px;}
    .section-label{font-size:0.75rem;font-weight:500;letter-spacing:0.12em;text-transform:uppercase;color:var(--accent);margin-bottom:1rem;}
    h1,h2{font-family:var(--serif);font-weight:300;line-height:1.2;}
    h1{font-size:clamp(2.2rem,5vw,4rem);margin-bottom:1.2rem;}
    h2{font-size:clamp(1.4rem,3vw,2.2rem);margin-bottom:1rem;margin-top:2.5rem;}
    h3{font-family:var(--serif);font-weight:400;font-size:1.15rem;margin-bottom:0.5rem;color:var(--text);}
    p{color:var(--muted);max-width:680px;margin-bottom:1.2rem;}
    .cards-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1.2rem;margin-top:1.5rem;}
    .card{background:var(--bg-card);border:1px solid var(--border);border-radius:8px;padding:1.5rem;box-shadow:0 1px 4px rgba(0,0,0,0.04);transition:box-shadow 0.2s,transform 0.2s;}
    .card:hover{box-shadow:0 6px 20px rgba(58,110,165,0.12);transform:translateY(-3px);}
    .card-icon{font-size:1.4rem;margin-bottom:0.75rem;}
    .card h3{font-size:1rem;}
    .card p{font-size:0.83rem;margin:0;}
    .tag-list{display:flex;flex-wrap:wrap;gap:0.5rem;margin-top:1.5rem;}
    .tag{background:var(--accent-light);color:var(--accent);font-size:0.78rem;padding:0.35rem 0.85rem;border-radius:100px;font-weight:500;}
    .divider{border:none;border-top:1px solid var(--border);margin:2.5rem 0;}
    footer{text-align:center;padding:2rem;font-size:0.82rem;color:var(--muted);border-top:1px solid var(--border);background:var(--bg);margin-top:4rem;}
    @media(max-width:768px){nav{padding:0 4vw;}.nav-links{gap:0.1rem;}}

    nav{position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(244,245,247,0.97);backdrop-filter:blur(10px);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;padding:0 6vw;height:68px;}
    .nav-brand{display:flex;align-items:center;gap:0.6rem;text-decoration:none;font-family:var(--serif);font-size:1.85rem;font-weight:600;color:var(--accent);letter-spacing:0.04em;}
    .nav-links{display:flex;gap:0.15rem;list-style:none;align-items:center;}
    .nav-links>li{position:relative;}
    /* plain links */
    .nav-links>li>a.nav-plain{display:block;padding:0.5rem 1rem;font-size:0.83rem;font-weight:500;color:var(--muted);text-decoration:none;letter-spacing:0.06em;text-transform:uppercase;border-radius:4px;transition:color 0.2s,background 0.2s;}
    .nav-links>li>a.nav-plain:hover,.nav-links>li>a.nav-plain.active{color:var(--accent);background:var(--accent-light);}
    /* dropdown trigger button */
    .nav-dd-btn{display:flex;align-items:center;gap:0.4rem;padding:0.5rem 1rem;font-size:0.83rem;font-weight:500;color:var(--muted);letter-spacing:0.06em;text-transform:uppercase;border-radius:4px;cursor:pointer;user-select:none;background:none;border:none;transition:color 0.2s,background 0.2s;white-space:nowrap;}
    .nav-dd-btn:hover,.nav-links>li.open .nav-dd-btn,.nav-links>li.active-section .nav-dd-btn{color:var(--accent);background:var(--accent-light);}
    .nav-dd-btn svg{width:12px;height:12px;flex-shrink:0;transition:transform 0.22s;stroke:currentColor;fill:none;stroke-width:2.2;stroke-linecap:round;stroke-linejoin:round;}
    .nav-links>li.open .nav-dd-btn svg{transform:rotate(180deg);}
    /* dropdown panel */
    .dd-menu{display:none;position:absolute;top:calc(100% + 6px);left:0;min-width:210px;background:var(--bg-card);border:1px solid var(--border);border-radius:10px;box-shadow:0 12px 32px rgba(0,0,0,0.13);overflow:hidden;z-index:200;}
    .nav-links>li.open .dd-menu{display:block;}
    .dd-menu a{display:flex;align-items:center;padding:0.8rem 1.3rem;font-size:0.86rem;font-weight:500;color:var(--text);text-decoration:none;transition:background 0.15s,color 0.15s;border-left:3px solid transparent;}
    .dd-menu a:hover{background:var(--accent-light);color:var(--accent);border-left-color:var(--accent);}
    .dd-menu a:not(:last-child){border-bottom:1px solid var(--border);}
    @media(max-width:768px){nav{padding:0 4vw;height:60px;}.nav-links{gap:0;}.nav-dd-btn,.nav-links>li>a.nav-plain{padding:0.45rem 0.7rem;font-size:0.78rem;}}

  </style>
</head>
